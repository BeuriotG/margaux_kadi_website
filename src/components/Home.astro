---
import { Image } from "astro:assets";
import portrait from "../assets/images/Margaux_Kadi_portrait.jpg";
import TCM from "../assets/icons/TCM.jpg";
---

<section
    class="flex flex-col justify-start gap-0 md:gap-2 md:min-h-screen w-full mx-auto p-2 md:p-5"
>
    <article
        class="flex flex-col md:flex-row md:justify-end items-center gap-2 h-full md:p-5"
    >
        <Image
            src={portrait}
            alt="Portrait de Margaux Kadi"
            class="img-rounded h-auto max-w-1/2 md:max-w-1/3 m-auto"
        />

        <div
            class="flex flex-col justify-center items-end h-full w-full md:h-auto md:w-2xl m-auto me-2 p-3"
        >
            <h1 class="capitalize text-home-page text-outline-red">
                <i>Margaux Kadi</i>
            </h1>
            <h3 class="uppercase text-home-page text-outline-pink">
                Coach vocale & professeure de technique vocale
            </h3>
        </div>
    </article>
    <Image
        src={TCM}
        alt={"Certification professionnelle Le Chanteur Moderne"}
        class="mx-auto md:mx-0 h-auto max-w-1/2 md:h-auto md:w-1/3 md:self-end"
    />
</section>
